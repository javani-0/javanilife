rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isPartner() {
      return hasRole('partner');
    }

    function isManager() {
      return hasRole('manager');
    }

    // Admin, or a MANAGER granted at least one of these admin pages (the page
    // keys the admin toggles on users/{uid}.managerPages — see Managers page).
    function staffAny(pages) {
      return isAdmin()
        || (isManager()
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('managerPages', []).hasAny(pages));
    }

    function isSafeOwnUserProfileWrite(userId) {
      return isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'user'
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'email',
          'phone',
          'whatsappNumber',
          'callNumber',
          'role',
          'createdAt',
          'updatedAt'
        ]);
    }

    function isSafeOwnUserProfileUpdate(userId) {
      return isOwner(userId)
        // Admin-created student accounts are managed by the admin — the parent
        // asks the admin for changes (the portal hides editing too).
        && resource.data.get('managedByAdmin', false) != true
        && request.resource.data.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'username',
          'phone',
          'whatsappNumber',
          'callNumber',
          'updatedAt'
        ]);
    }

    match /products/{id} {
      allow read: if true;
      allow write: if staffAny(['products']);
    }

    match /orders/{id} {
      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid;
      allow read: if staffAny(['orders', 'customers', 'finance'])
        || (signedIn() && resource.data.customerId == request.auth.uid);
      allow update, delete: if staffAny(['orders']);
    }

    match /userTokens/{tokenId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'token',
          'uid',
          'enabled',
          'platform',
          'userAgent',
          'browserPlatform',
          'createdAt',
          'updatedAt',
          'errorMessage'
        ]);
      allow delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // Finance config (e.g. finance/settings: partner identity + profit share %).
    // Admin writes; admin + partner read (the partner dashboard needs the % and
    // partner name — no customer data lives here).
    match /finance/{id} {
      allow read: if staffAny(['finance']) || isPartner();
      allow write: if isAdmin();
    }

    // Partners — website logos + optional financial access & per-category profit
    // shares (req 4). Public read so the site can show partner logos and the
    // admin console can list them; only an admin writes. (No customer PII here;
    // partner login/share config lives on these docs.)
    match /partners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Partner sign-in credentials (email + password) the admin creates so they
    // can re-share on WhatsApp (req 4). ADMIN-ONLY — never public. Writes happen
    // server-side via the Admin SDK; admin reads here to display/share.
    match /partnerCredentials/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Manager sign-in credentials the admin creates (req) — ADMIN-ONLY, same
    // model as partnerCredentials. Writes happen server-side (Admin SDK).
    match /managerCredentials/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Student Manager (req): admin-created student profiles + onboarding state.
    // Staff with the `students` page manage them; approval writes (STU id,
    // login, enrolment) happen server-side via the Admin SDK.
    match /students/{id} {
      allow read, write: if staffAny(['students']);
    }

    // Student sign-in credentials (email + password = STU id) — staff-only,
    // same plaintext-for-resharing model as partner/manager credentials. Writes
    // happen server-side (Admin SDK) at approval.
    match /studentCredentials/{id} {
      allow read: if staffAny(['students']);
      allow write: if staffAny(['students']);
    }

    // Public onboarding payment links. Read by DIRECT token only (never listed)
    // so a parent can open their own link without logging in; every parent-side
    // change goes through the server (Admin SDK). Staff manage/refresh the doc.
    match /onboardingLinks/{token} {
      allow get: if true;
      allow list: if staffAny(['students']);
      allow write: if staffAny(['students']);
    }

    // Server-only counters (e.g. counters/studentIds → next STU id). No client
    // access; the Admin SDK bypasses these rules.
    match /counters/{id} {
      allow read, write: if false;
    }

    // Business expenses — admin enters/edits; admin + partner may read. The
    // partner dashboard reads aggregates via the server, but allowing read here
    // keeps the admin console working and exposes no customer PII.
    match /expenses/{id} {
      allow read: if staffAny(['finance']) || isPartner();
      allow write: if staffAny(['finance']);
    }

    // Manually-entered extra income — same access model as expenses.
    match /manualIncome/{id} {
      allow read: if staffAny(['finance']) || isPartner();
      allow write: if staffAny(['finance']);
    }

    match /courses/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /gallery/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /enquiries/{id} {
      allow create: if true;
      allow read, update, delete: if signedIn();
    }

    match /siteSettings/{id} {
      allow read: if true;
      allow write: if staffAny(['site-settings', 'payment-settings', 'delivery-settings']);
    }

    match /coupons/{code} {
      allow read: if true;
      allow write: if staffAny(['coupons']);
    }

    // Faculty collection — public read, authenticated write
    match /faculty/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    // Users collection — user can read/write own doc
    match /users/{userId} {
      allow read: if isOwner(userId) || staffAny(['customers']);
      allow create: if isSafeOwnUserProfileWrite(userId) || isAdmin();
      allow update: if isSafeOwnUserProfileUpdate(userId) || isAdmin();

      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /webPushTokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    // History collection — user can read/write own history entries
    match /history/{historyId} {
      allow create: if signedIn();
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // ── Classes (monthly fee + autopay) ──────────────────────────────────

    // Class catalog — public read, admin write.
    match /classes/{id} {
      allow read: if true;
      allow write: if staffAny(['classes']);
    }

    // Enrollments — parent owns their student records; admin has full access.
    // Money/status/autopay transitions are driven server-side (Admin SDK) or by
    // an admin; a parent may only keep their own ownership on update.
    match /enrollments/{id} {
      allow read: if staffAny(['enrollments', 'fee-collections', 'classes', 'students'])
        || (signedIn() && resource.data.parentUserId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.parentUserId == request.auth.uid;
      allow update: if staffAny(['enrollments', 'fee-collections', 'students'])
        || (signedIn()
            && resource.data.parentUserId == request.auth.uid
            && request.resource.data.parentUserId == request.auth.uid);
      allow delete: if staffAny(['enrollments']);
    }

    // Fee ledger — parent reads own; all money-bearing writes are server-side
    // (webhook/cron via Admin SDK, which bypasses rules) or an admin console.
    match /feePayments/{id} {
      allow read: if staffAny(['fee-collections', 'enrollments', 'customers', 'finance', 'students'])
        || (signedIn() && resource.data.parentUserId == request.auth.uid);
      allow write: if staffAny(['fee-collections', 'enrollments', 'students']);
    }
  }
}
