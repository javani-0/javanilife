# Razorpay server credentials for Vercel API routes.
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_CURRENCY=INR
# Optional public key id for Vite clients. Never expose RAZORPAY_KEY_SECRET.
VITE_RAZORPAY_KEY_ID=rzp_test_replace_me

# Firebase Admin credentials for server-side order verification updates.
# Use either FIREBASE_SERVICE_ACCOUNT as one JSON string, or the split values below.
FIREBASE_PROJECT_ID=javani-181d5
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-replace@javani-181d5.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"javani-181d5","private_key":"-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-replace@javani-181d5.iam.gserviceaccount.com"}

# Preferred Firebase Admin option for Vercel/serverless: base64 encode the full service account JSON.
FIREBASE_ADMIN_SDK_BASE64=replace_with_base64_service_account_json

# Firebase web push certificate public key. This is safe for frontend use.
# Copy the full public key from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates.
VITE_FIREBASE_VAPID_KEY=replace_with_firebase_web_push_certificate_public_key
PUBLIC_APP_URL=https://your-production-domain.example

# WhatsApp template language (all custom templates use "en").
VITE_WHATSAPP_TEMPLATE_LANGUAGE=en

# WhatsApp template names for order-placed notifications.
# Template params: order_confirmed    → firstName, orderNumber, itemsSummary, total  + URL button
#                  admin_order_alert  → orderNumber, itemsSummary, total, customerName + URL button
VITE_WHATSAPP_ORDER_PLACED_CUSTOMER_TEMPLATE=order_confirmed
VITE_WHATSAPP_ORDER_PLACED_ADMIN_TEMPLATE=admin_order_alert
# Order-status templates (outForDelivery/delivered/cancelled/refunded) are mapped
# per-status in notifications.ts — no separate env var needed.

# WhatsApp Cloud API server credentials.
WHATSAPP_TOKEN=replace_me
WHATSAPP_PHONE_ID=1112943475226121
WHATSAPP_OTP_TEMPLATE=otp_login
WHATSAPP_OTP_LANG=en