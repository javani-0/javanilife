# Razorpay server credentials for Vercel API routes.
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_CURRENCY=INR
# Optional public key id for Vite clients. Never expose RAZORPAY_KEY_SECRET.
VITE_RAZORPAY_KEY_ID=rzp_test_replace_me

# Firebase Admin credentials for server-side order verification updates.
# Use either FIREBASE_SERVICE_ACCOUNT as one JSON string, or the split values below.
FIREBASE_PROJECT_ID=javani-181d5
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-replace@javani-181d5.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"javani-181d5","private_key":"-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-replace@javani-181d5.iam.gserviceaccount.com"}

# Preferred Firebase Admin option for Vercel/serverless: base64 encode the full service account JSON.
FIREBASE_ADMIN_SDK_BASE64=replace_with_base64_service_account_json

# Firebase web push certificate public key. This is safe for frontend use.
# Copy the full public key from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates.
VITE_FIREBASE_VAPID_KEY=replace_with_firebase_web_push_certificate_public_key
PUBLIC_APP_URL=https://your-production-domain.example

# WhatsApp template language (all custom templates use "en").
VITE_WHATSAPP_TEMPLATE_LANGUAGE=en

# WhatsApp template names for order-placed notifications.
# Template params: order_confirmed    → firstName, orderNumber, itemsSummary, total  + URL button
#                  admin_order_alert  → orderNumber, itemsSummary, total, customerName + URL button
VITE_WHATSAPP_ORDER_PLACED_CUSTOMER_TEMPLATE=order_confirmed
VITE_WHATSAPP_ORDER_PLACED_ADMIN_TEMPLATE=admin_order_alert
VITE_WHATSAPP_COURSE_INSTALLMENT_REMINDER_TEMPLATE=course_installment_reminder
# Order-status templates (outForDelivery/delivered/cancelled/refunded) are mapped
# per-status in notifications.ts — no separate env var needed.

# WhatsApp Cloud API server credentials.
WHATSAPP_TOKEN=replace_me
WHATSAPP_PHONE_ID=1112943475226121
WHATSAPP_COURSE_INSTALLMENT_REMINDER_TEMPLATE=course_installment_reminder
WHATSAPP_OTP_TEMPLATE=otp_login
WHATSAPP_OTP_LANG=en

# Vercel cron authorization shared secret for scheduled server jobs.
CRON_SECRET=replace_me

# --- Classes / monthly fee autopay (Razorpay Subscriptions reuse existing
#     RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET) ---
# Required for the webhook to verify subscription + payment events.
RAZORPAY_WEBHOOK_SECRET=replace_me

# Class fee WhatsApp templates (create these in Meta Business Manager).
# class_fee_reminder     → parentFirstName, studentName, className, amount, dueDate    + URL button
# class_fee_paid_parent  → parentFirstName, studentName, className, amount, monthLabel + URL button
# class_fee_paid_admin   → studentName, className, amount, monthLabel, parentName      + URL button
# class_fee_failed       → parentFirstName, studentName, className, amount, dueDate     + URL button
VITE_WHATSAPP_CLASS_FEE_REMINDER_TEMPLATE=class_fee_reminder
WHATSAPP_CLASS_FEE_REMINDER_TEMPLATE=class_fee_reminder
VITE_WHATSAPP_CLASS_FEE_PAID_PARENT_TEMPLATE=class_fee_paid_parent
WHATSAPP_CLASS_FEE_PAID_PARENT_TEMPLATE=class_fee_paid_parent
VITE_WHATSAPP_CLASS_FEE_PAID_ADMIN_TEMPLATE=class_fee_paid_admin
WHATSAPP_CLASS_FEE_PAID_ADMIN_TEMPLATE=class_fee_paid_admin
VITE_WHATSAPP_CLASS_FEE_FAILED_TEMPLATE=class_fee_failed
WHATSAPP_CLASS_FEE_FAILED_TEMPLATE=class_fee_failed

# Class-fee reminder cron tuning.
CLASS_FEE_REMINDER_DAYS=5
CLASS_FEE_REMINDER_LIMIT=100

# Delhivery / Delivery One shipment creation.
# DELIVERY_ONE_PICKUP_LOCATION must exactly match the warehouse name registered in Delhivery.
DELIVERY_ONE_ENVIRONMENT=production
DELIVERY_ONE_API_TOKEN=replace_me
DELIVERY_ONE_PICKUP_LOCATION=replace_with_registered_warehouse_name
DELIVERY_ONE_SHIPPING_MODE=Surface
# Optional return/seller details shown on the Delhivery manifest.
DELIVERY_ONE_SELLER_NAME=Javani Spiritual Hub
DELIVERY_ONE_SELLER_ADDRESS=replace_with_pickup_or_business_address
DELIVERY_ONE_RETURN_NAME=Javani Spiritual Hub
DELIVERY_ONE_RETURN_ADDRESS=replace_with_return_address
DELIVERY_ONE_RETURN_CITY=replace_with_return_city
DELIVERY_ONE_RETURN_STATE=replace_with_return_state
DELIVERY_ONE_RETURN_PIN=replace_with_return_pincode
DELIVERY_ONE_RETURN_PHONE=replace_with_return_phone
