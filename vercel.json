{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "javanailife.store" }],
      "destination": "/products",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.javanailife.store" }],
      "destination": "/products",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/razorpay?action=webhook" },
    { "source": "/api/razorpay/create-emi-subscription", "destination": "/api/razorpay?action=create-emi-subscription" },
    { "source": "/api/razorpay/pay-emi-installment", "destination": "/api/razorpay?action=pay-emi-installment" },
    { "source": "/api/razorpay/:action", "destination": "/api/razorpay?action=:action" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/share/products/:id", "destination": "/api/share-page?type=product&id=:id" },
    { "source": "/share/courses/:id", "destination": "/api/share-page?type=course&id=:id" },
    { "source": "/((?!api/|@vite/|@react-refresh|.*\\..*).*)", "destination": "/" }
  ],
  "crons": [
    { "path": "/api/cron/delivery-tracking", "schedule": "0 2 * * *" },
    { "path": "/api/cron/course-installments", "schedule": "0 5 * * *" },
    { "path": "/api/cron/class-fee-reminders", "schedule": "0 4 * * *" }
  ]
}