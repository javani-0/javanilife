{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "javanailife.store" }],
      "destination": "/products",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.javanailife.store" }],
      "destination": "/products",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/razorpay/webhook" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/products/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(whatsapp|facebookexternalhit|twitterbot|telegrambot|linkedinbot|slackbot|discordbot|applebot|googlebot|bingbot|yandexbot|bot|crawler|spider|preview|scraper).*" }],
      "destination": "/api/share-page?type=product&id=:id"
    },
    {
      "source": "/courses/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(whatsapp|facebookexternalhit|twitterbot|telegrambot|linkedinbot|slackbot|discordbot|applebot|googlebot|bingbot|yandexbot|bot|crawler|spider|preview|scraper).*" }],
      "destination": "/api/share-page?type=course&id=:id"
    },
    { "source": "/share/products/:id", "destination": "/api/share-page?type=product&id=:id" },
    { "source": "/share/courses/:id", "destination": "/api/share-page?type=course&id=:id" },
    { "source": "/((?!api/|@vite/|@react-refresh|.*\\..*).*)", "destination": "/" }
  ],
  "crons": [
    { "path": "/api/cron/delivery-tracking", "schedule": "0 2 * * *" },
    { "path": "/api/cron/course-installments", "schedule": "0 5 5 * *" }
  ]
}